# ERP base URL (no trailing slash)
ERP_API_URL=http://localhost:5000

# Shared secret key between the ERP and this portal
# Generate with: openssl rand -hex 32
PORTAL_API_KEY=your_portal_api_key_here

# Default campus slug (used when neither ?ref= nor ?slug= is provided)
DEFAULT_CAMPUS_SLUG=dakar-centre

# Portal public URL (used in WhatsApp share links)
NEXT_PUBLIC_PORTAL_URL=https://portail.votreecole.com

# Client-side campus slug (for the quiz page in direct mode)
NEXT_PUBLIC_DEFAULT_CAMPUS_SLUG=dakar-centre

# Brand name shown in navbar, footer, badge, titles
NEXT_PUBLIC_BRAND_NAME=AcadERP

# Plausible analytics — leave empty to disable (dev). E.g.: portail.ecole.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional: Plausible script URL (self-hosted)
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.tagged-events.js
